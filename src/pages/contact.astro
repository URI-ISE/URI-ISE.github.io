---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="URI ISE | Contact">
  <section class="page-header section-compact">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="tagline">Partner with the URI Industrial & Systems Engineering Group</p>
    </div>
  </section>

  <!-- ===== Main Contact Content ===== -->
  <section class="section section-compact">
    <div class="container">
      <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
        
        <!-- Contact Form Card -->
        <article class="contact-card">
          <h3>Send a Message</h3>
          <p>
            Interested in research collaboration, the Industry 4.0 Certificate, or learning more about our lab? Reach out.
          </p>
          <p style="margin-top: 0.75rem; color: var(--text-muted);">
            All inquiries are currently forwarded to sodhi@uri.edu.
          </p>
          <form id="contact-form">
            <label for="name" class="visually-hidden" style="display:none;">Name</label>
            <input type="text" id="name" name="name" placeholder="Your Name" required />

            <label for="email" class="visually-hidden" style="display:none;">Email</label>
            <input type="email" id="email" name="email" placeholder="Your Email Address" required />

            <label for="subject" class="visually-hidden" style="display:none;">Subject</label>
            <select id="subject" name="subject" required style="border: 1px solid var(--input-border); border-radius: 8px; padding: 0.6rem 0.8rem; background: var(--input-bg); color: var(--text);">
              <option value="" disabled selected>Topic of Inquiry</option>
              <option value="research">Research Partnerships</option>
              <option value="certificate">Industry 4.0 Certificate</option>
              <option value="prospective-student">Prospective Student Inquiry</option>
              <option value="other">Other</option>
            </select>

            <label for="message" class="visually-hidden" style="display:none;">Message</label>
            <textarea id="message" name="message" placeholder="How can we help you?" required></textarea>

            <button type="submit" class="button primary">Submit Inquiry</button>
          </form>
          <p style="margin-top: 0.75rem; color: var(--text-muted); font-size: 0.95rem;">
            Your email client will open with the subject format: ISEURI Forward: Topic.
          </p>
        </article>

        <!-- Lab Location & Details -->
        <article class="card">
          <h3>Physical Location</h3>
          <p>
            The ISE Group operates primarily within the <strong>Fascitelli Center for Advanced Engineering</strong>, housing our smart manufacturing platforms, digital twin infrastructure, and optimization labs.
          </p>
          <div style="margin: 1.5rem 0;">
            <p style="margin: 0; color: var(--text);"><strong>Fascitelli Center for Advanced Engineering</strong></p>
            <p style="margin: 0; color: var(--text-muted);">2 East Alumni Ave</p>
            <p style="margin: 0; color: var(--text-muted);">Kingston, RI 02881</p>
          </div>
          <h3>Key Contacts</h3>
          <p style="margin-top: 0.5rem; margin-bottom: 0.2rem;"><strong>Laboratory Director</strong></p>
          <p style="margin: 0;"><a href="mailto:sodhi@uri.edu">Manbir Sodhi, PhD</a></p>
          
          <div style="margin-top: 2rem;">
            <a class="button secondary" href="https://web.uri.edu/engineering/about/facilities/" target="_blank" rel="noopener">View Campus Map &rarr;</a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <script is:inline>
    const contactForm = document.getElementById("contact-form");

    if (contactForm) {
      contactForm.addEventListener("submit", (event) => {
        event.preventDefault();

        const name = document.getElementById("name")?.value?.trim() || "";
        const email = document.getElementById("email")?.value?.trim() || "";
        const topic = document.getElementById("subject")?.value || "other";
        const message = document.getElementById("message")?.value?.trim() || "";

        const topicMap = {
          research: "Research Partnerships",
          certificate: "Industry 4.0 Certificate",
          "prospective-student": "Prospective Student Inquiry",
          other: "Other"
        };

        const topicExtension = topicMap[topic] || "Other";
        const subject = `ISEURI Forward: ${topicExtension}`;
        const body = [
          `Name: ${name}`,
          `Email: ${email}`,
          `Topic: ${topicExtension}`,
          "",
          "Message:",
          message
        ].join("\n");

        window.location.href = `mailto:sodhi@uri.edu?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      });
    }
  </script>
</BaseLayout>
