---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="URI Industrial & Systems Engineering">
    <section class="hero">
        <canvas id="supply-chain-canvas" class="hero-canvas" aria-hidden="true"></canvas>
        <div class="hero-noise-overlay"></div>
        <div class="hero-gradient-overlay"></div>
        <div class="container hero-content">
            <p class="tagline">Optimization · Machine Learning · Smart Manufacturing</p>
            <h1>URI Industrial & Systems Engineering</h1>
            <p>
                The URI ISE Group develops optimization algorithms, machine-learning models, digital-twin
                simulations, and data-driven pipelines that advance manufacturing, logistics, and industrial
                systems for academic, industry, and public-sector partners.
            </p>
            <div class="hero-actions">
                <a class="button primary" href="/projects">Explore Research</a>
                <a class="button secondary" href="/contact">Partner With Us</a>
            </div>
        </div>
    </section>

    <section class="section section-compact">
        <div class="container">
            <div class="section-header">
                <h2>Mission</h2>
                <p>
                    Applying optimization, machine learning, and systems engineering to advance
                    manufacturing, logistics, and industrial infrastructure.
                </p>
            </div>
            <div class="page-header-media" style="margin-bottom:1.5rem;">
                <img src="/assets/photos/uri-testbed.webp" alt="Top-down view of the URI ISE manufacturing testbed" class="page-header-img" loading="lazy" />
            </div>
            <div class="card-grid">
                <article class="card">
                    <h3>Optimization &amp; Scheduling</h3>
                    <p>From production scheduling to supply-chain networks, we develop algorithms that improve throughput and reduce cost.</p>
                </article>
                <article class="card">
                    <h3>Machine Learning &amp; Data</h3>
                    <p>Genetic algorithms, computer vision, and predictive models for manufacturing process control and quality assurance.</p>
                </article>
                <article class="card">
                    <h3>Digital Twins &amp; Simulation</h3>
                    <p>High-fidelity simulation environments for testing, validation, and chaos engineering of industrial systems.</p>
                </article>
            </div>
        </div>
    </section>

    <section class="section section-compact">
        <div class="container">
            <div class="section-header">
                <h2>Research Areas</h2>
                <p>Six integrated threads spanning algorithms, hardware, and data infrastructure.</p>
            </div>
            <div class="card-grid card-grid-3x2">
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M7 7h.01"/><path d="M17 7h.01"/><path d="M7 17h.01"/><path d="M17 17h.01"/><path d="M12 2v20"/><path d="M2 12h20"/></svg>
                    <h3>Digital Twins</h3>
                    <p>High-fidelity simulation environments for testing, validation, and chaos engineering of industrial systems.</p>
                </article>
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m13.5 8.5-5 5"/><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <h3>Smart Mfg &amp; CNC</h3>
                    <p>GCode interception, sensor-rich machining, and custom tooling fabrication on in-house equipment.</p>
                </article>
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>
                    <h3>Optimization</h3>
                    <p>Production scheduling, multi-agent coordination, and genetic ML algorithms for process control.</p>
                </article>
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
                    <h3>Vision &amp; QC</h3>
                    <p>Computer vision for real-time defect detection, dimensional measurement, and robotic pick-and-place.</p>
                </article>
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="M2 12h2"/><path d="M20 12h2"/></svg>
                    <h3>Data &amp; IIoT</h3>
                    <p>End-to-end sensor data pipelines, SCADA integration, and real-time operational dashboards.</p>
                </article>
                <article class="card icon-card">
                    <svg class="icon-card-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    <h3>Cyber-Physical</h3>
                    <p>Resilient edge architectures, testbed orchestration, and secure operation under degraded connectivity.</p>
                </article>
            </div>
            <div class="section-cta">
                <a class="button secondary" href="/projects">View All Research &rarr;</a>
            </div>
        </div>
    </section>

    <section class="section section-compact">
        <div class="container">
            <div class="section-header">
                <h2>Graduate Certificate in Industry 4.0</h2>
                <p>A 12-credit, fully online credential for working professionals.</p>
            </div>
            <div class="card-grid">
                <article class="card">
                    <h3>12 Credits · 4 Courses</h3>
                    <p>A focused, stackable credential covering IIoT, machine learning, MES, and special projects.</p>
                </article>
                <article class="card">
                    <h3>100 % Online</h3>
                    <p>Complete the certificate entirely online — designed around the schedules of working professionals.</p>
                </article>
                <article class="card">
                    <h3>Career-Ready Skills</h3>
                    <p>Industry-aligned knowledge in smart manufacturing, data analytics, and cyber-physical systems.</p>
                </article>
            </div>
            <div class="section-cta">
                <a class="button primary" href="/industry4-0#certificate">Learn More &rarr;</a>
            </div>
        </div>
    </section>

    <script is:inline>
        function initFlowCanvas() {
            if (window.supplyChainAnimId) {
                cancelAnimationFrame(window.supplyChainAnimId);
            }

            const canvas = document.getElementById('supply-chain-canvas');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            let width, height;

            function resize() {
                width = canvas.width = window.innerWidth;
                height = canvas.height = canvas.offsetHeight || window.innerHeight * 0.7;
            }
            window.addEventListener('resize', resize);
            resize();

            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            const colorNode = isDark ? 'rgba(81, 162, 255, ' : 'rgba(0, 80, 158, ';
            const colorHub = isDark ? 'rgba(179, 156, 77, ' : 'rgba(179, 156, 77, '; // Golden
            const colorFlow = isDark ? 'rgba(179, 156, 77, ' : 'rgba(179, 156, 77, ';
            const colorMapStroke = isDark ? 'rgba(255, 255, 255, 0.08)' : 'rgba(0, 33, 71, 0.1)';
            
            // Dynamic number of nodes based on screen width
            const numNodes = Math.min(Math.floor(width / 20), 80);
            
            // Central Hub: URI Kingston Campus
            const uriHub = {
                id: 'hub',
                x: width * 0.32,
                y: height * 0.72,
                baseRadius: 6,
                pulse: 0
            };
            
            const nodes = [];
            for (let i = 0; i < numNodes; i++) {
                nodes.push({
                    x: Math.random() * width,
                    y: Math.random() * height,
                    vx: (Math.random() - 0.5) * 0.3,
                    vy: (Math.random() - 0.5) * 0.3,
                    radius: Math.random() * 2 + 1
                });
            }

            const packages = [];
            
            function spawnPackage() {
                if (packages.length > 25) return;
                
                // Favor lines connected to the Hub
                let start, end;
                if (Math.random() > 0.4) {
                    const toHub = Math.random() > 0.5;
                    const randomNode = nodes[Math.floor(Math.random() * nodes.length)];
                    start = toHub ? randomNode : uriHub;
                    end = toHub ? uriHub : randomNode;
                } else {
                    start = nodes[Math.floor(Math.random() * nodes.length)];
                    end = nodes[Math.floor(Math.random() * nodes.length)];
                }
                
                packages.push({
                    start,
                    end,
                    progress: 0,
                    speed: 0.002 + Math.random() * 0.003
                });
            }

            // Spawn loop
            setInterval(spawnPackage, 400);

            function drawMapOutline() {
                ctx.lineWidth = 1;
                ctx.strokeStyle = colorMapStroke;
                
                // Stylized abstract coastline (Narragansett / South County area)
                ctx.beginPath();
                ctx.moveTo(0, height * 0.4);
                ctx.lineTo(width * 0.15, height * 0.5);
                ctx.lineTo(width * 0.25, height * 0.75);
                ctx.lineTo(width * 0.35, height * 1.05);   // Point Judith
                ctx.lineTo(width * 0.42, height * 0.85);
                ctx.lineTo(width * 0.45, height * 0.5);    // West Passage up
                ctx.lineTo(width * 0.55, height * 0.2);    // Providence
                ctx.lineTo(width * 0.65, height * 0.5);    // East passage down
                ctx.lineTo(width * 0.70, height * 0.8);
                ctx.lineTo(width * 0.85, height * 0.9);
                ctx.lineTo(width * 0.95, height * 0.6);
                ctx.lineTo(width, height * 0.4);
                ctx.stroke();

                // Aquidneck Island (Newport)
                ctx.beginPath();
                ctx.moveTo(width * 0.52, height * 0.6);
                ctx.lineTo(width * 0.50, height * 0.95);
                ctx.lineTo(width * 0.62, height * 0.90);
                ctx.lineTo(width * 0.60, height * 0.55);
                ctx.closePath();
                ctx.stroke();

                // Conanicut Island (Jamestown)
                ctx.beginPath();
                ctx.moveTo(width * 0.45, height * 0.65);
                ctx.lineTo(width * 0.44, height * 0.85);
                ctx.lineTo(width * 0.47, height * 0.82);
                ctx.lineTo(width * 0.48, height * 0.62);
                ctx.closePath();
                ctx.stroke();
            }

            function draw() {
                ctx.clearRect(0, 0, width, height);
                
                // Ensure Hub stays accurate on resize
                uriHub.x = width * 0.32;
                uriHub.y = height * 0.72;
                
                drawMapOutline();

                // Move and draw standard nodes
                nodes.forEach(p => {
                    p.x += p.vx;
                    p.y += p.vy;
                    if (p.x < 0 || p.x > width) p.vx *= -1;
                    if (p.y < 0 || p.y > height) p.vy *= -1;

                    ctx.beginPath();
                    ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
                    ctx.fillStyle = colorNode + '0.6)';
                    ctx.fill();
                });

                // Draw logical connections
                ctx.lineWidth = 1;
                for (let i = 0; i < nodes.length; i++) {
                    // Connect nodes to Hub
                    const dhx = nodes[i].x - uriHub.x;
                    const dhy = nodes[i].y - uriHub.y;
                    const distHub = Math.sqrt(dhx*dhx + dhy*dhy);
                    if (distHub < 250) {
                        ctx.beginPath();
                        ctx.moveTo(nodes[i].x, nodes[i].y);
                        ctx.lineTo(uriHub.x, uriHub.y);
                        const alpha = Math.max(0, 0.4 - distHub / 250);
                        ctx.strokeStyle = colorFlow + alpha + ')';
                        ctx.stroke();
                    }

                    // Local connections
                    for (let j = i + 1; j < nodes.length; j++) {
                        const dx = nodes[i].x - nodes[j].x;
                        const dy = nodes[i].y - nodes[j].y;
                        const dist = Math.sqrt(dx * dx + dy * dy);

                        if (dist < 100) {
                            ctx.beginPath();
                            ctx.moveTo(nodes[i].x, nodes[i].y);
                            ctx.lineTo(nodes[j].x, nodes[j].y);
                            const alpha = Math.max(0, 0.3 - dist / 100);
                            ctx.strokeStyle = colorNode + alpha + ')';
                            ctx.stroke();
                        }
                    }
                }
                
                // Draw Packages moving along edges
                for (let i = packages.length - 1; i >= 0; i--) {
                    const pkg = packages[i];
                    pkg.progress += pkg.speed;
                    
                    if (pkg.progress >= 1) {
                        packages.splice(i, 1);
                        continue;
                    }

                    const currentX = pkg.start.x + (pkg.end.x - pkg.start.x) * pkg.progress;
                    const currentY = pkg.start.y + (pkg.end.y - pkg.start.y) * pkg.progress;
                    
                    ctx.beginPath();
                    ctx.arc(currentX, currentY, 2.5, 0, Math.PI * 2);
                    ctx.fillStyle = '#ffffff';
                    ctx.fill();
                    // Glow effect for packages
                    ctx.shadowBlur = 8;
                    ctx.shadowColor = '#ffffff';
                    ctx.fill();
                    ctx.shadowBlur = 0;
                }

                // Draw URI Kingston Hub
                uriHub.pulse += 0.05;
                const dynamicRadius = uriHub.baseRadius + Math.sin(uriHub.pulse) * 2;
                
                ctx.beginPath();
                ctx.arc(uriHub.x, uriHub.y, dynamicRadius, 0, Math.PI * 2);
                ctx.fillStyle = colorHub + '1)';
                ctx.fill();
                
                ctx.beginPath();
                ctx.arc(uriHub.x, uriHub.y, dynamicRadius * 2, 0, Math.PI * 2);
                ctx.fillStyle = colorHub + '0.3)';
                ctx.fill();
                
                // Hub Text Label
                ctx.font = '600 12px var(--font-family, sans-serif)';
                ctx.fillStyle = colorHub + '1)';
                ctx.fillText('URI KINGSTON', uriHub.x + 15, uriHub.y + 4);

                window.supplyChainAnimId = requestAnimationFrame(draw);
            }
            draw();
        }

        document.addEventListener("astro:page-load", initFlowCanvas);
        if (!document.documentElement.hasAttribute('data-astro-transition')) {
            initFlowCanvas();
        }
    </script>
</BaseLayout>
