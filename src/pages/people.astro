---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="URI ISE | People">
  <section class="page-header section-compact">
    <div class="container">
      <h1>People</h1>
      <p class="tagline">A multi-level team focused on industrial systems engineering research and practical applications.</p>
    </div>
  </section>

  <section class="section section-compact">
    <div class="container profile-grid">
      <div class="profile-section">
        <h2>Principal Advisor</h2>
        <article class="profile-card large">
          <div class="avatar"><img src="/assets/photos/manbir-sodhi.webp" alt="Dr. Manbir Sodhi" /></div>
          <div class="profile-meta">
            <strong>Dr. Manbir Sodhi</strong>
            <span class="profile-role">Professor & Lab Director</span>
            <a href="mailto:manbir.sodhi@uri.edu">sodhi@uri.edu</a>
            <p>Leads industry & systems engineering and strategic industry partnerships.</p>
            <div style="margin-top:0.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; font-size:0.85rem;">
                <a href="https://scholar.google.com/citations?user=kI1Mg1MAAAAJ&hl=en&oi=sra" style="color:var(--text-muted); text-decoration:underline;">[ Google Scholar ]</a>
                <a href="https://github.com/sodhims" style="color:var(--text-muted); text-decoration:underline;">[ GitHub Profile ]</a>
            </div>
          </div>
        </article>
      </div>

      <div class="profile-section">
        <h2>Post-Doctoral Fellow</h2>
        <article class="profile-card">
          <div class="avatar"><img src="/assets/photos/romesh-prasad.webp" alt="Dr. Romesh Prasad" /></div>
          <div class="profile-meta">
            <strong>Dr. Romesh Prasad</strong>
            <a href="mailto:romeshsatish.prasad@uri.edu">romeshsatish.prasad@uri.edu</a>
            <p>Focuses on digital twin and machine learning applications in manufacturing.</p>
            <div style="margin-top:0.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; font-size:0.85rem;">
                <a href="https://scholar.google.com/citations?user=VDbBU3kAAAAJ&hl=en" style="color:var(--text-muted); text-decoration:underline;">[ Google Scholar ]</a>
                <a href="https://github.com/romeshprasad" style="color:var(--text-muted); text-decoration:underline;">[ GitHub Profile ]</a>
            </div>
          </div>
        </article>
      </div>

      <div class="profile-section">
        <h2>Doctoral Students</h2>
        <div class="card-grid">
          <article class="profile-card">
            <div class="avatar"><img src="/assets/photos/steven-blum.webp" alt="Steven Blum" /></div>
            <div class="profile-meta">
              <strong>Steven Blum</strong>
              <a href="mailto:steven.blum@uri.edu">steven.blum@uri.edu</a>
              <p>Optimization and scheduling integration with personalized user workflows.</p>
              <div style="margin-top:0.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; font-size:0.85rem;">
                  <a href="https://www.linkedin.com/in/steven-blum-93523068/" style="color:var(--text-muted); text-decoration:underline;">[ LinkedIn ]</a>
                  <a href="https://github.com/stevenblum" style="color:var(--text-muted); text-decoration:underline;">[ GitHub Profile ]</a>
              </div>
            </div>
          </article>
          <article class="profile-card">
            <div class="avatar"><img src="/assets/photos/stephen-eacuello.webp" alt="Stephen Eacuello" /></div>
            <div class="profile-meta">
              <strong>Stephen Eacuello</strong>
              <a href="mailto:seacuello@uri.edu">seacuello@uri.edu</a>
              <p>Develops GCode interception and validation for CNC machining systems.</p>
              <div style="margin-top:0.5rem; display:flex; gap:0.5rem; flex-wrap:wrap; font-size:0.85rem;">
                  <a href="https://scholar.google.com/citations?user=PjOwd54AAAAJ&hl=en&oi=sra" style="color:var(--text-muted); text-decoration:underline;">[ Google Scholar ]</a>
                  <a href="https://www.linkedin.com/in/stephen-salvatore-eacuello-a2a92242/" style="color:var(--text-muted); text-decoration:underline;">[ LinkedIn ]</a>
                  <a href="https://github.com/stephenseacuello" style="color:var(--text-muted); text-decoration:underline;">[ GitHub Profile ]</a>
              </div>
            </div>
          </article>
        </div>
      </div>

