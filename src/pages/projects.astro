---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="URI ISE | Projects">
  <section class="page-header section-compact">
    <div class="container">
      <h1>Projects</h1>
      <p class="tagline">Applied demos, tools, and lab-built software.</p>
      <p>Research topics now live on the dedicated Research Topics page so this page can stay focused on project demos and utilities.</p>
    </div>
  </section>

  <section class="section section-compact">
    <div class="container">
      <div class="section-header">
        <h2>Projects &amp; Tools</h2>
        <p>Applied software and demos built and maintained by the lab.</p>
      </div>
      <div class="card-grid">
        <article class="card project-card">
          <span>Applied Systems</span>
          <h3>Tower of Hanoi Solver</h3>
          <p>Interactive solver and algorithmic visualization for production scheduling reasoning.</p>
          <a class="button primary" href="/hanoi/">Open Project</a>
        </article>
        <article class="card project-card">
          <span>Human-Centered</span>
          <h3>RSVP Speed Reader</h3>
          <p>Rapid serial visual presentation research tool for cognitive workflows.</p>
          <a class="button primary" href="/rsvp-reading/">Open Project</a>
        </article>
      </div>
      <div class="section-cta">
        <a class="button secondary" href="/research">Explore Research Topics &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>
