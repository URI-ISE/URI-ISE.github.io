---
const target = "/people/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <title>URI ISE | People</title>
    <script is:inline>
      window.location.replace('/people/');
    </script>
  </head>
  <body>
    <p>Redirecting to <a href="/people/">People</a>...</p>
  </body>
</html>
